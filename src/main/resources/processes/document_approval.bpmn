<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.34.0">
  <bpmn:process id="document_approval" name="Document Approval" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1" />
    <bpmn:userTask id="SubmitDocument" default="f2" camunda:assignee="creator" />
    <bpmn:userTask id="ManagerApprove" default="f3" camunda:assignee="manager" />
    <bpmn:userTask id="DirectorApprove" camunda:assignee="director" />
    <bpmn:exclusiveGateway id="ManagerDecision" />
    <bpmn:exclusiveGateway id="DirectorDecision" />
    <bpmn:endEvent id="ApprovedEnd" />
    <bpmn:endEvent id="RejectedEnd" />
    <bpmn:sequenceFlow id="f1" sourceRef="StartEvent_1" targetRef="SubmitDocument" />
    <bpmn:sequenceFlow id="f2" sourceRef="SubmitDocument" targetRef="ManagerApprove" />
    <bpmn:sequenceFlow id="f3" sourceRef="ManagerApprove" targetRef="ManagerDecision" />
    <bpmn:sequenceFlow id="f4" sourceRef="ManagerDecision" targetRef="DirectorApprove">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression"> ${managerApproved == 1}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f5" sourceRef="ManagerDecision" targetRef="RejectedEnd">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${managerApproved == 0}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f6" sourceRef="DirectorApprove" targetRef="DirectorDecision" />
    <bpmn:sequenceFlow id="f7" sourceRef="DirectorDecision" targetRef="ApprovedEnd">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${directorApproved == 1}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f8" sourceRef="DirectorDecision" targetRef="RejectedEnd">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${directorApproved == 0}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="document_approval">
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="160" y="120" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SubmitDocument_di" bpmnElement="SubmitDocument">
        <dc:Bounds x="240" y="100" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ManagerApprove_di" bpmnElement="ManagerApprove">
        <dc:Bounds x="380" y="100" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="DirectorApprove_di" bpmnElement="DirectorApprove">
        <dc:Bounds x="620" y="100" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ManagerDecision_di" bpmnElement="ManagerDecision" isMarkerVisible="true">
        <dc:Bounds x="520" y="115" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="DirectorDecision_di" bpmnElement="DirectorDecision" isMarkerVisible="true">
        <dc:Bounds x="760" y="115" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ApprovedEnd_di" bpmnElement="ApprovedEnd">
        <dc:Bounds x="880" y="100" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="RejectedEnd_di" bpmnElement="RejectedEnd">
        <dc:Bounds x="880" y="180" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="f1_di" bpmnElement="f1">
        <di:waypoint x="196" y="138" />
        <di:waypoint x="240" y="140" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f2_di" bpmnElement="f2">
        <di:waypoint x="340" y="140" />
        <di:waypoint x="380" y="140" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f3_di" bpmnElement="f3">
        <di:waypoint x="480" y="140" />
        <di:waypoint x="520" y="140" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f4_di" bpmnElement="f4">
        <di:waypoint x="570" y="140" />
        <di:waypoint x="620" y="140" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f6_di" bpmnElement="f6">
        <di:waypoint x="720" y="140" />
        <di:waypoint x="760" y="140" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f5_di" bpmnElement="f5">
        <di:waypoint x="545" y="165" />
        <di:waypoint x="680" y="290" />
        <di:waypoint x="882" y="206" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f7_di" bpmnElement="f7">
        <di:waypoint x="810" y="140" />
        <di:waypoint x="880" y="118" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f8_di" bpmnElement="f8">
        <di:waypoint x="785" y="165" />
        <di:waypoint x="880" y="198" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
